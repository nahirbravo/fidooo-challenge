NEXT_PUBLIC_EMULATOR_AUTH_HOST=localhost:9099
NEXT_PUBLIC_EMULATOR_FIRESTORE_HOST=localhost:8080

# Firebase Admin SDK for server session cookies
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

